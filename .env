# ─────────────────────────────────────────────────────────────
#  Birthday Wishes App — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Gmail OAuth2 token (required for sending emails via Gmail API)
# Get this by running the OAuth2 flow once and serialising the token
GOOGLE_TOKEN_JSON={"token":"YOUR_TOKEN","refresh_token":"YOUR_REFRESH_TOKEN","token_uri":"https://oauth2.googleapis.com/token","client_id":"YOUR_CLIENT_ID","client_secret":"YOUR_CLIENT_SECRET","scopes":["https://www.googleapis.com/auth/gmail.send"]}

# Server port (optional, default: 5000)
PORT=5000

# Email defaults (can also be set via the Settings UI)
EMAIL_SENDER=yourname@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Scheduler defaults
SEND_TIME=08:00
TIMEZONE=Asia/Kolkata
